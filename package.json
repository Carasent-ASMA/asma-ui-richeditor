{
    "name": "asma-ui-richeditor",
    "publishConfig": {
        "access": "public"
    },
    "version": "0.0.0",
    "type": "module",
    "files": [
        "dist/**/*",
        "dist/style.css",
        "tw-configs/**/*"
    ],
    "keywords": [],
    "author": "asma-team",
    "types": "./dist/index.d.ts",
    "main": "./dist/asma-ui-richeditor.es.js",
    "module": "./dist/asma-ui-richeditor.es.js",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/asma-ui-richeditor.es.js"
            }
        },
        "./dist/style.css": "./dist/style.css",
        "./tw-configs/twConfigs.json": "./tw-configs/twConfigs.json"
    },
    "repository": {
        "url": "https://github.com:Carasent-ASMA/asma-ui-richeditor.git"
    },
    "scripts": {
        "dev": "vite",
        "build": "npx tsc && rm -rf ./dist && vite build",
        "preview": "vite preview",
        "lint": "eslint src/**/*.{js,jsx,ts,tsx}",
        "version": "echo $npm_package_version",
        "lint:fix": "eslint --fix src/**/*.{jsx,ts,tsx}",
        "prettier": "prettier --write src//**/*.{ts,tsx,scss} --config ./.prettierrc",
        "storybook": "storybook dev -p 6006",
        "storybook:no-browser": "storybook dev -p 6006 --no-open",
        "storybook:node18": "export NODE_OPTIONS=--openssl-legacy-provider && storybook dev -p 6006",
        "storybook:node18:win": "set NODE_OPTIONS=--openssl-legacy-provider && storybook dev -p 6006",
        "build-storybook": "export NODE_OPTIONS=--max_old_space_size=6240 && storybook build",
        "test-storybook": "test-storybook",
        "changeset:pre-beta": "changeset pre enter beta",
        "changeset:pre-exit": "changeset pre exit",
        "changeset:version": "changeset version",
        "changeset:publish": "changeset publish",
        "changeset:status": "changeset status"
    },
    "license": "UNLICENSED",
    "dependencies": {
        "@emotion/react": "^11.11.1",
        "@emotion/styled": "^11.11.0",
        "@iconify/react": "^5.0.2",
        "@mui/material": "^5.13.7",
        "@tiptap/core": "^2.11.7",
        "@tiptap/extension-bold": "^2.11.7",
        "@tiptap/extension-bullet-list": "^2.11.7",
        "@tiptap/extension-document": "^2.11.7",
        "@tiptap/extension-heading": "^2.11.7",
        "@tiptap/extension-italic": "^2.11.7",
        "@tiptap/extension-link": "^2.11.7",
        "@tiptap/extension-list-item": "^2.11.7",
        "@tiptap/extension-ordered-list": "^2.11.7",
        "@tiptap/extension-paragraph": "^2.11.7",
        "@tiptap/extension-placeholder": "^2.11.7",
        "@tiptap/extension-text": "^2.27.2",
        "@tiptap/extension-text-style": "^2.11.7",
        "@tiptap/react": "^2.11.7",
        "clsx": "^2.1.1",
        "emoji-picker-react": "^4.13.2",
        "tiptap-extension-font-size": "^1.2.0"
    },
    "devDependencies": {
        "@changesets/cli": "^2.26.2",
        "@rollup/plugin-terser": "^0.4.3",
        "@storybook/addon-a11y": "^10.4.0",
        "@storybook/addon-docs": "^10.4.0",
        "@storybook/addon-links": "^10.4.0",
        "@storybook/addon-themes": "^10.4.0",
        "@storybook/react": "^10.4.0",
        "@storybook/react-vite": "^10.4.0",
        "@storybook/test-runner": "^0.24.4",
        "@types/node": "^18.0.3",
        "@types/react": "^18.3.28",
        "@typescript-eslint/eslint-plugin": "^5.59.0",
        "@typescript-eslint/parser": "^5.59.0",
        "@vitejs/plugin-react": "^6.0.2",
        "asma-ui-core": "^3.3.7",
        "autoprefixer": "^10.5.0",
        "axe-playwright": "^1.2.3",
        "esbuild": "^0.28.0",
        "eslint": "^8.38.0",
        "eslint-plugin-react-hooks": "^4.6.0",
        "eslint-plugin-react-refresh": "^0.3.4",
        "eslint-plugin-storybook": "^0.6.15",
        "postcss": "^8.5.15",
        "postcss-import": "^16.1.1",
        "react": "18.2.0",
        "react-dom": "18.2.0",
        "remark-gfm": "^4.0.1",
        "storybook": "^10.4.0",
        "tailwind-merge": "^2.4.0",
        "tailwind-scrollbar": "^3.1.0",
        "tailwindcss": "^3.3.2",
        "typescript": "^5.9.3",
        "typescript-plugin-css-modules": "^5.0.1",
        "vite": "^8.0.13",
        "vite-plugin-dts": "^5.0.1"
    },
    "peerDependencies": {
        "@emotion/react": "^11.*",
        "@emotion/styled": "^11.*",
        "@mui/material": "^5.*",
        "asma-ui-core": "^3.3.7",
        "react": "^18.2.0 || ^19.0.0",
        "react-dom": "^18.2.0 || ^19.0.0"
    }
}

